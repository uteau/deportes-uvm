// Prisma Schema — Plataforma Deportiva UVM
// Documentación: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Rol {
  estudiante
  admin
}

enum EventoSubtipo {
  partido
  evento_publico
}

enum AnuncioTipo {
  publico
  seluvm
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model Usuario {
  id                    String    @id @default(uuid())
  nombre                String
  email                 String    @unique
  password_hash         String
  rol                   Rol       @default(estudiante)
  is_active             Boolean   @default(true)
  deporte               String?
  estudiante_id         String?   @unique
  credential_expires_at DateTime?
  last_login            DateTime?
  created_at            DateTime  @default(now())

  // Relaciones
  eventos  Evento[]
  anuncios Anuncio[]

  @@map("usuarios")
}

model Evento {
  id            String        @id @default(uuid())
  nombre        String
  descripcion   String?
  fecha_evento  DateTime
  lugar         String
  subtipo       EventoSubtipo
  equipo_local  String?
  equipo_visita String?
  resul_local   Int?
  resul_visita  Int?
  promoted_at   DateTime?
  is_active     Boolean       @default(true)
  created_by    String
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  // Relaciones
  creador Usuario @relation(fields: [created_by], references: [id])

  @@map("eventos")
}

model Anuncio {
  id            String      @id @default(uuid())
  titulo        String
  contenido     String
  tipo          AnuncioTipo
  instagram_url String?
  is_published  Boolean     @default(true)
  created_by    String
  published_at  DateTime?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  // Relaciones
  creador Usuario @relation(fields: [created_by], references: [id])

  @@map("anuncios")
}

model Contacto {
  id                  String  @id @default(uuid())
  nombre              String
  rol                 String?
  email               String?
  telefono            String?
  descripcion_servicio String?

  @@map("contactos")
}
