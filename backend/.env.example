DATABASE_URL="postgresql://user:password@localhost:5432/deportes_uvm"
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_STUDENT="8h"
JWT_EXPIRES_ADMIN="4h"
PORT=3000

# ── Seed de administradores ────────────────────────────────────────────────────
# Ejecutar con: npm run seed
ADMIN_EMAIL=admin@uvm.cl
ADMIN_PASSWORD=change_me_in_production
ADMIN_NOMBRE=Administrador UVM

# Admin secundario (opcional — solo se crea si ADMIN2_PASSWORD está definida)
# ADMIN2_EMAIL=admin2@uvm.cl
# ADMIN2_PASSWORD=change_me_in_production
# ADMIN2_NOMBRE=Administrador UVM 2
